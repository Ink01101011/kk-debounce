{
  "name": "kk-debounce",
  "version": "1.0.2",
  "description": "The Next-Generation Debounce Library for 2026. Built for the modern web with native Temporal API support, AbortSignal integration, and Fine-grained Reactivity.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./debounce": {
      "import": {
        "types": "./dist/debounce.d.ts",
        "default": "./dist/debounce.js"
      },
      "require": {
        "types": "./dist/debounce.d.cts",
        "default": "./dist/debounce.cjs"
      }
    },
    "./debounceSignal": {
      "import": {
        "types": "./dist/debounceSignal.d.ts",
        "default": "./dist/debounceSignal.js"
      },
      "require": {
        "types": "./dist/debounceSignal.d.cts",
        "default": "./dist/debounceSignal.cjs"
      }
    },
    "./react": {
      "import": {
        "types": "./dist/react.d.ts",
        "default": "./dist/react.js"
      },
      "require": {
        "types": "./dist/react.d.cts",
        "default": "./dist/react.cjs"
      }
    },
    "./throttle": {
      "import": {
        "types": "./dist/throttle.d.ts",
        "default": "./dist/throttle.js"
      },
      "require": {
        "types": "./dist/throttle.d.cts",
        "default": "./dist/throttle.cjs"
      }
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": null
    }
  },
  "files": [
    "dist",
    "README.md",
    "DEVELOP.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "check:cve": "pnpm audit --prod --audit-level moderate",
    "check:cve:full": "pnpm audit --audit-level moderate",
    "check:all": "pnpm run typecheck && pnpm run lint && pnpm run format && pnpm run test && pnpm run build && pnpm run check:cve",
    "prepare": "husky",
    "prepublishOnly": "pnpm run check:all"
  },
  "keywords": [
    "debounce",
    "temporal",
    "abortsignal",
    "reactive",
    "signals",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.44.1",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0"
  },
  "author": "Ink01101011",
  "homepage": "https://github.com/Ink01101011/kk-debounce#readme",
  "bugs": {
    "url": "https://github.com/Ink01101011/kk-debounce/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ink01101011/kk-debounce.git"
  }
}
